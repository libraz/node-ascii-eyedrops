{
	"name": "@libraz/ascii-eyedrops",
	"version": "0.1.0",
	"description": "True Visual Programming for JavaScript — transform your code into executable ASCII art",
	"type": "module",
	"engines": {
		"node": ">=16"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"pako": "^2.1.0"
	},
	"optionalDependencies": {
		"sharp": "^0.34.5"
	},
	"peerDependencies": {
		"terser": "^5.0.0"
	},
	"peerDependenciesMeta": {
		"terser": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/node": "^25.5.2",
		"@types/pako": "^2.0.4",
		"@vitest/coverage-v8": "^4.1.2",
		"sharp": "^0.34.5",
		"terser": "^5.46.1",
		"tsup": "^8.5.1",
		"typescript": "^5.8.3",
		"vitest": "^4.1.2"
	},
	"volta": {
		"node": "22.14.0",
		"yarn": "4.12.0"
	},
	"license": "MIT"
}
